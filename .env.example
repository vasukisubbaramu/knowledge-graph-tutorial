# Copy to .env and fill in.
# .env is gitignored.

# Required: Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Defaults — change only if you know why
KG_MODEL_DEFAULT=claude-sonnet-4-6
KG_MODEL_REASONING=claude-opus-4-7
KG_EMBED_MODEL=BAAI/bge-small-en-v1.5

# Neo4j (Desktop default)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-tutorial

# Local paths
KG_DATA_DIR=./data/synthetic
KG_CHROMA_DIR=./data/chroma_db

# Set to 1 to print every Claude call (helps when learning)
KG_VERBOSE_LLM=0
